import React, { useState } from 'react';
import { View, Text, TouchableOpacity, TextInput, ScrollView, SafeAreaView, Alert } from 'react-native';
import auth from '@react-native-firebase/auth';

// Simulação de backend IA (pode ser substituído por OpenAI real)
const generateContent = async (type, prompt) => {
  return `${type} gerado para: ${prompt}`;
};

export default function MoneyAIApp() {
  const [email, setEmail] = useState('');
  const [password, setPassword] = useState('');
  const [user, setUser] = useState(null);
  const [prompt, setPrompt] = useState('');
  const [result, setResult] = useState('');

  // Login com Firebase
  const login = async () => {
    try {
      const res = await auth().signInWithEmailAndPassword(email, password);
      setUser(res.user);
    } catch (err) {
      Alert.alert('Erro', err.message);
    }
  };

  // Criar conta com Firebase
  const signup = async () => {
    try {
      const res = await auth().createUserWithEmailAndPassword(email, password);
      setUser(res.user);
    } catch (err) {
      Alert.alert('Erro', err.message);
    }
  };

  // Gerar Ebook/Ideia
  const generateEbook = async () => {
    if (!prompt.trim()) {
      Alert.alert('Atenção', 'Digite um tema ou ideia.');
      return;
    }
    const text = await generateContent('Ebook', prompt);
    setResult(text);
  };

  // Simulação de pagamento
  const handlePayment = (plan) => {
    Alert.alert('Pagamento', `Redirecionando para pagamento do plano: ${plan}`);
  };

  // Tela de login
  if (!user) {
    return (
      <SafeAreaView style={{ flex: 1, justifyContent: 'center', alignItems: 'center', padding: 20 }}>
        <Text style={{ fontSize: 24, fontWeight: 'bold', marginBottom: 20 }}>🚀 MoneyAI Angola</Text>
        <TextInput
          placeholder="Email"
          value={email}
          onChangeText={setEmail}
          style={{ borderWidth: 1, padding: 10, width: '100%', marginBottom: 12, borderRadius: 8 }}
        />
        <TextInput
          placeholder="Senha"
          value={password}
          secureTextEntry
          onChangeText={setPassword}
          style={{ borderWidth: 1, padding: 10, width: '100%', marginBottom: 12, borderRadius: 8 }}
        />
        <TouchableOpacity
          onPress={login}
          style={{ backgroundColor: 'black', padding: 12, borderRadius: 12, width: '100%', marginBottom: 8 }}
        >
          <Text style={{ color: 'white', textAlign: 'center' }}>Entrar</Text>
        </TouchableOpacity>
        <TouchableOpacity
          onPress={signup}
          style={{ borderWidth: 1, padding: 12, borderRadius: 12, width: '100%' }}
        >
          <Text style={{ textAlign: 'center' }}>Criar Conta</Text>
        </TouchableOpacity>
      </SafeAreaView>
    );
  }

  // Tela principal do app
  return (
    <SafeAreaView style={{ flex: 1 }}>
      <ScrollView contentContainerStyle={{ padding: 20 }}>
        <Text style={{ fontSize: 22, fontWeight: 'bold', marginBottom: 16 }}>💡 Gerador de Ebook / Ideias</Text>
        <TextInput
          placeholder="Escreva a ideia ou tema"
          value={prompt}
          onChangeText={setPrompt}
          style={{ borderWidth: 1, padding: 12, borderRadius: 12, marginBottom: 12 }}
        />
        <TouchableOpacity
          onPress={generateEbook}
          style={{ backgroundColor: 'black', padding: 12, borderRadius: 12, marginBottom: 16 }}
        >
          <Text style={{ color: 'white', textAlign: 'center' }}>Gerar</Text>
        </TouchableOpacity>
        {result ? <Text style={{ marginBottom: 20, fontSize: 16 }}>{result}</Text> : null}

        <Text style={{ fontSize: 22, fontWeight: 'bold', marginBottom: 16 }}>💳 Planos</Text>
        {['Grátis', 'PRO', 'Vitalício'].map((plan) => (
          <TouchableOpacity
            key={plan}
            onPress={() => handlePayment(plan)}
            style={{ borderWidth: 1, borderRadius: 12, padding: 12, marginBottom: 12 }}
          >
            <Text style={{ fontSize: 18 }}>{plan}</Text>
          </TouchableOpacity>
        ))}

        <TouchableOpacity
          onPress={() => auth().signOut().then(() => setUser(null))}
          style={{ marginTop: 20, backgroundColor: 'red', padding: 12, borderRadius: 12 }}
        >
          <Text style={{ color: 'white', textAlign: 'center' }}>Logout</Text>
        </TouchableOpacity>
      </ScrollView>
    </SafeAreaView>
  );
}
